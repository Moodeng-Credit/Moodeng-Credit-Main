# Build Configuration
GENERATE_SOURCEMAP=false
CI=true
NEXT_TELEMETRY_DISABLED=1

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://localhost:3000
PORT=5000

# Wallet Connect
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id

# Database
MONGO_URI=your_mongodb_connection_string

# JWT Authentication
JWT_SECRET=your_jwt_secret_key

# Email Configuration
EMAIL_USER=your_email@example.com
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REFRESH_TOKEN=your_google_refresh_token

# Telegram Bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_telegram_bot_username
TELEGRAM_API_TOKEN=your_telegram_bot_token
TELEGRAM_API_URL=https://api.telegram.org/bot<YOUR_TOKEN>/sendMessage
webhookAPI=https://api.telegram.org/bot<YOUR_TOKEN>/setWebhook
webhookUrl=your_webhook_url

# CORS Configuration
CORS_ORIGINS=http://127.0.0.1:3000,https://127.0.0.1:3000,http://localhost:3000

# World ID (Worldcoin)
NEXT_PUBLIC_WORLD_ID_APP_ID=your_world_id_app_id
WORLD_ID_API_KEY=your_world_id_api_key
NEXT_PUBLIC_WORLD_ID_ACTION_ID=verify

# Development Mode (shows unverify button for testing)
NEXT_PUBLIC_DEV_MODE=true

# USDC Contract Addresses (optional - defaults to mainnet if not set)
# Uncomment and set these to override the default mainnet addresses for testing
# Base Mainnet USDC (default): 0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
# Base Sepolia USDC (default): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# NEXT_PUBLIC_BASE_USDC_ADDRESS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
# NEXT_PUBLIC_BASE_SEPOLIA_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# OAuth (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_ID=your_google_client_id

# USDC contracts
  NEXT_PUBLIC_BASE_USDC_ADDRESS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
  NEXT_PUBLIC_BASE_SEPOLIA_USDC_ADDRESS=0x96dFcfbDec0F50Ee08cde3ca3BCDe044BdDa9D39