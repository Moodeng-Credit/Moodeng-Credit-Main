FROM node:24-alpine

WORKDIR /app

# Install pnpm globally using npm
RUN npm install -g pnpm@10.11.0

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies on container startup (for hot reload of new deps)
# Copy rest of the application
COPY . .

# Expose port 3000
EXPOSE 3000

# Install dependencies and run the development server with hot reload.
# Ensure frontend/.env.local and frontend/.env.keys exist (copy from repo root) so dotenvx can decrypt.
COPY docker-start.sh /app/docker-start.sh
RUN chmod +x /app/docker-start.sh
CMD ["sh", "/app/docker-start.sh"]
