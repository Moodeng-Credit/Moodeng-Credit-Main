FROM node:24-alpine

WORKDIR /app

# Install pnpm globally using npm
RUN npm install -g pnpm@10.11.0

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies on container startup (for hot reload of new deps)
# Copy rest of the application
COPY . .

# Expose port 3000
EXPOSE 3000

# Install dependencies and run the development server with hot reload.
# Prefer .env.local (plain vars for Docker); else .env.staging (needs .env.keys to decrypt); else vite with no env.
CMD ["sh", "-c", "pnpm install && if [ -f .env.local ]; then pnpm run dev:local --host 0.0.0.0; elif [ -f .env.staging ]; then pnpm run dev --host 0.0.0.0; else npx vite --host 0.0.0.0; fi"]
