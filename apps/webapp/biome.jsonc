{
  "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
  "root": false,
  "extends": "//",
  "files": {
    "includes": ["**", "!**/routeTree.gen.ts"]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noUnknownAtRules": "off",
        "noArrayIndexKey": "off"
      },
      "a11y": {
        "useButtonType": "off"
      }
    }
  }
}
