# World Id
NEXT_PUBLIC_WORLD_ID_APP_ID=app_staging_45afca29a686140c059e725b0d5bc6a4
WORLD_ID_API_KEY=xxx
NEXT_PUBLIC_WORLD_ID_ACTION_ID=verify

# show un verify button
NEXT_PUBLIC_DEV_MODE=true