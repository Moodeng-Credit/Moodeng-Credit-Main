// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorldIdStatus {
  INACTIVE
  ACTIVE
}

enum LoanStatus {
  Requested
  Lent
}

enum RepaymentStatus {
  Unpaid
  Partial
  Paid
}

model User {
  id                String         @id @default(cuid())
  walletAddress     String?        @unique
  username          String         @unique
  isWorldId         WorldIdStatus
  nullifierHash     String?        @unique
  password          String?
  email             String         @unique
  googleId          String?        @unique
  telegramId        BigInt?        @unique
  telegramUsername  String?        @unique
  chatId            BigInt?        @unique
  mal               Int            @default(3)
  nal               Int            @default(0)
  cs                Int            @default(15)
  resetToken        String?        @unique
  resetTokenExpiry  DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Loan {
  id                    String           @id @default(cuid())
  trackingId            String           @unique
  borrowerWallet        String?
  lenderWallet          String?
  borrowerUser          String?
  lenderUser            String?
  loanAmount            Decimal          @db.Decimal(18, 6)
  repaidAmount          Decimal          @default(0) @db.Decimal(18, 6)
  totalRepaymentAmount  Decimal          @db.Decimal(18, 6)
  reason                String
  loanStatus            LoanStatus
  repaymentStatus       RepaymentStatus
  days                  Int
  block                 String
  coin                  String
  hash                  String[]         @default([])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt


  @@index([borrowerUser])
  @@index([lenderUser])
  @@index([borrowerWallet])
  @@index([lenderWallet])
  @@index([loanStatus])
  @@index([repaymentStatus])
  @@index([createdAt])
  @@index([lenderWallet, loanStatus])
  @@index([createdAt, loanStatus])
}
