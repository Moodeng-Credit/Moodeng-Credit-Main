{
   "name": "@repo/moodeng",
   "version": "1.0.0",
   "private": true,
   "exports": {
      ".": {
         "import": "./src/export/index.ts",
         "types": "./src/export/index.ts"
      }
   },
   "scripts": {
      "dev": "next dev",
      "dev:local": "NODE_ENV=development NEXT_SKIP_TYPESCRIPT_CHECK=true NODE_OPTIONS='--max-old-space-size=8192' NODE_TLS_REJECT_UNAUTHORIZED=0  next dev --experimental-https",
      "build": "NODE_ENV=production next build",
      "start": "next start ",
      "reup": "rm -rf node_modules && rm -rf .next && npm install",
      "=== Build / Format Helpers ===": "",
      "format_build": "bash ./scripts/formatInstallBuild.sh",
      "clean": "bash ./scripts/clean.sh",
      "clean_build": "bash ./scripts/cleanBuild.sh",
      "clean_build_run": "bash ./scripts/cleanBuildAndRun.sh dev",
      "clean_build_run_local": "bash ./scripts/cleanBuildAndRun.sh dev:local",
      "clean_build_run_prd": "bash ./scripts/cleanBuildAndRun.sh",
      "clean_build_run_next": "bash ./scripts/cleanBuildAndRunNext.sh dev",
      "clean_build_run_next_local": "bash ./scripts/cleanBuildAndRunNext.sh dev:local",
      "clean_build_run_next_prd": "bash ./scripts/cleanBuildAndRunNext.sh",
      "=== helpers ===": "",
      "lint": "NODE_ENV=production eslint \"src/**/*.{js,jsx,ts,tsx}\"",
      "lint:time": "NODE_ENV=production TIMING=all eslint  \"src/**/*.{js,jsx,ts,tsx}\"",
      "lint:fix": "NODE_ENV=production eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
      "prettier": "prettier --list-different --write \"src/**/*.{js,jsx,ts,tsx}\"",
      "type-check": "tsc --noEmit",
      "check-all": "npm run type-check && npm run lint:fix && npm run lint",
      "format": "npm run prettier",
      "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
      "biome:format": "biome format",
      "biome:format:write": "biome format --write",
      "biome:lint": "biome lint",
      "biome:lint:write": "biome lint --write",
      "biome:check": "biome check",
      "biome:check:write": "biome check --write"
   },
   "dependencies": {
      "@fortawesome/fontawesome-free": "^7.1.0",
      "@lukemorales/query-key-factory": "^1.3.4",
      "@rainbow-me/rainbowkit": "2.2.9",
      "@react-oauth/google": "^0.12.2",
      "@reduxjs/toolkit": "^2.11.0",
      "@supabase/ssr": "^0.8.0",
      "@supabase/supabase-js": "^2.87.0",
      "@tanstack/react-form": "^1.27.1",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-query-devtools": "^5.91.1",
      "@worldcoin/idkit": "2.4.2",
      "autoprefixer": "^10.4.22",
      "axios": "^1.13.2",
      "bcryptjs": "^3.0.3",
      "clsx": "^2.1.1",
      "date-fns": "^4.1.0",
      "google-auth-library": "^10.5.0",
      "googleapis": "^166.0.0",
      "js-cookie": "^3.0.5",
      "jsonwebtoken": "^9.0.2",
      "jwt-decode": "^4.0.0",
      "lightgallery": "^2.9.0",
      "lucide-react": "^0.555.0",
      "next": "15.5.7",
      "nodemailer": "^7.0.11",
      "postcss": "^8.5.6",
      "radix-ui": "^1.4.3",
      "react": "19.2.0",
      "react-day-picker": "^9.11.3",
      "react-dom": "19.2.0",
      "react-media": "^1.10.0",
      "react-redux": "^9.2.0",
      "react-router-dom": "^7.9.6",
      "redux-persist": "^6.0.0",
      "sass": "^1.94.2",
      "tailwindcss": "^3.4.17",
      "viem": "2.38.1",
      "wagmi": "2.18.0",
      "zod": "^4.1.13",
      "zustand": "^5.0.9"
   },
   "devDependencies": {
      "@biomejs/biome": "2.2.4",
      "@eslint/eslintrc": "^3.3.3",
      "@next/eslint-plugin-next": "^15.5.5",
      "@tanstack/eslint-plugin-query": "^5.91.2",
      "@trivago/prettier-plugin-sort-imports": "^5.2.2",
      "@types/js-cookie": "^3.0.6",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/node": "^22.13.5",
      "@types/nodemailer": "^7.0.4",
      "@types/pg": "^8.15.6",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "dotenv": "^17.2.3",
      "eslint": "^9.39.1",
      "eslint-config-next": "^15.5.5",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-import": "^2.32.0",
      "eslint-plugin-react-refresh": "^0.4.24",
      "eslint-plugin-unused-imports": "^4.3.0",
      "prettier": "^3.7.2",
      "typescript": "^5.9.3"
   },
   "engines": {
      "node": ">=22.0.0"
   }
}
